generator client {
  provider = "prisma-client-js"
  // output              = "../src/generated"
  // importFileExtension = "ts"
  // moduleFormat        = "esm"
  // previewFeatures = ["omitApi"]
  // binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// Platform model
model Platform {
  id String @id @unique @default("main")

  totalScans        Int @default(0)
  totalScansDenied  Int @default(0)
  totalScansGranted Int @default(0)

  authLoginEnabled     Boolean @default(false)
  authSignupEnabled    Boolean @default(false)
  authSignupInviteOnly Boolean @default(false)
}
