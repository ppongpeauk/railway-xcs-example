{
	"name": "web",
	"type": "module",
	"scripts": {
		"dev": "next dev --turbo",
		"build": "NEXT_PUBLIC_GIT_SHA=${NEXT_PUBLIC_GIT_SHA:-$(git rev-parse --short HEAD 2>/dev/null || echo 'dev')} NEXT_PUBLIC_GIT_BRANCH=${NEXT_PUBLIC_GIT_BRANCH:-$(git branch --show-current 2>/dev/null || echo 'dev')} next build --turbo",
		"build:railway": "NEXT_PUBLIC_GIT_SHA=${RAILWAY_GIT_COMMIT_SHA:-unknown} NEXT_PUBLIC_GIT_BRANCH=${RAILWAY_GIT_BRANCH:-unknown} next build --turbo",
		"start": "next start",
		"lint": "next lint",
		"typecheck": "tsc --noEmit"
	},
	"prisma": {
		"migrate:dev": "dotenv -e .env.development -- npx prisma migrate deploy",
		"migrate:prod": "dotenv -e .env -- npx prisma migrate deploy"
	},
